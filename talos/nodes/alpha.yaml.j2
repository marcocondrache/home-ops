---
machine:
  type: controlplane
  nodeLabels:
    # ponytail: reuse queen's zone "m" if same rack; change if alpha sits elsewhere
    topology.kubernetes.io/zone: m
---
apiVersion: v1alpha1
kind: HostnameConfig
hostname: alpha
---
apiVersion: v1alpha1
kind: LinkAliasConfig
name: net0
selector:
  # ponytail: placeholder — set alpha's real NIC MAC before apply, else no net0/bond0
  match: mac(link.permanent_addr) == "00:00:00:00:00:00"
