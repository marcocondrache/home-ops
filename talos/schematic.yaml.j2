---
customization:
  extraKernelArgs:
    - -selinux
    - iommu.passthrough=1
    - amd_pstate=active # AMD P-State
    - thunderbolt.host_reset=0 # Thunderbolt NICs
    - talos.dashboard.disabled=1
    - talos.auditd.disabled=1
  systemExtensions:
    officialExtensions:
      - siderolabs/amdgpu
      - siderolabs/amd-ucode
      - siderolabs/thunderbolt
      - siderolabs/realtek-firmware
      - siderolabs/drbd
