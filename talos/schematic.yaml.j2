---
customization:
  extraKernelArgs:
    - -selinux
    - amd_iommu=on
    - amd_pstate=active
    - iommu.passthrough=1
    - talos.dashboard.disabled=1
    - talos.auditd.disabled=1
  systemExtensions:
    officialExtensions:
      - siderolabs/amdgpu
      - siderolabs/amd-ucode
      - siderolabs/realtek-firmware
      - siderolabs/drbd
