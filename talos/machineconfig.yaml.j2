---
version: v1alpha1
machine:
  ca:
    crt: ref+op://hive/talos/CERT_OS_CRT
    {% if ENV.CONTROLPLANE %}
    key: ref+op://hive/talos/CERT_OS_KEY
    {% endif %}
  features:
    apidCheckExtKeyUsage: true
    diskQuotaSupport: true
    hostDNS:
      enabled: true
      forwardKubeDNSToHost: true # Requires Cilium socketLB features
      resolveMemberNames: true
    kubePrism:
      enabled: true
      port: 7445
    {% if ENV.CONTROLPLANE %}
    kubernetesTalosAPIAccess:
      enabled: true
      allowedKubernetesNamespaces:
        - actions-runner-system
        - system-upgrade
      allowedRoles:
        - os:admin
    {% endif %}
    rbac: true
  files:
    - op: create
      path: /etc/cri/conf.d/20-customization.part
      content: |
        [plugins."io.containerd.cri.v1.images"]
          discard_unpacked_layers = false
        [plugins."io.containerd.cri.v1.runtime"]
          device_ownership_from_security_context = true
    - op: overwrite
      path: /etc/nfsmount.conf
      permissions: 0o644
      content: |
        [ NFSMount_Global_Options ]
        nfsvers=4.2
        hard=True
        nconnect=8
        noatime=True
        rsize=1048576
        wsize=1048576
  install:
    diskSelector:
        type: nvme
    image: factory.talos.dev/metal-installer/{{ ENV.SCHEMATIC }}:v1.13.6
    wipe: false
  kernel:
    modules:
      - name: nbd
      - name: thunderbolt
      - name: thunderbolt_net
      - name: dm_thin_pool
      - name: drbd_transport_tcp
      - name: drbd
        parameters:
          - usermode_helper=disabled
  kubelet:
    defaultRuntimeSeccompProfileEnabled: true
    disableManifestsDirectory: true
    extraConfig:
      serializeImagePulls: false
      shutdownGracePeriod: 90s
      shutdownGracePeriodCriticalPods: 60s
    image: ghcr.io/siderolabs/kubelet:v1.36.2
    nodeIP:
      validSubnets:
        - 10.0.30.0/24
  nodeLabels:
    node.kubernetes.io/gpu: "true"
    topology.kubernetes.io/region: main
  sysctls:
    fs.inotify.max_user_instances: "8192"
    fs.inotify.max_user_watches: "1048576"
    net.core.default_qdisc: fq
    net.core.rmem_max: "67108864"
    net.core.wmem_max: "67108864"
    net.ipv4.neigh.default.gc_thresh1: "4096"
    net.ipv4.neigh.default.gc_thresh2: "8192"
    net.ipv4.neigh.default.gc_thresh3: "16384"
    net.ipv4.ping_group_range: 0 2147483647
    net.ipv4.tcp_congestion_control: bbr
    net.ipv4.tcp_fastopen: "3"
    net.ipv4.tcp_mtu_probing: "1"
    net.ipv4.tcp_notsent_lowat: "131072"
    net.ipv4.tcp_rmem: 4096 87380 33554432
    net.ipv4.tcp_slow_start_after_idle: "0"
    net.ipv4.tcp_window_scaling: "1"
    net.ipv4.tcp_wmem: 4096 65536 33554432
    net.ipv6.conf.all.accept_ra: "2"
    net.ipv6.conf.all.forwarding: "1"
    net.ipv6.conf.bond0.accept_ra: "2"
    sunrpc.tcp_max_slot_table_entries: "128"
    sunrpc.tcp_slot_table_entries: "128"
    user.max_user_namespaces: "11255"
    vm.nr_hugepages: "1024"
  token: ref+op://hive/talos/TRUSTDINFO_TOKEN
cluster:
  ca:
    crt: ref+op://hive/talos/CERT_K8S_CRT
    {% if ENV.CONTROLPLANE %}
    key: ref+op://hive/talos/CERT_K8S_KEY
    {% endif %}
  clusterName: hive
  controlPlane:
    endpoint: https://k8s.labx.internal:6443
  discovery:
    enabled: true
    registries:
      kubernetes:
        disabled: true
      service:
        disabled: false
  id: ref+op://hive/talos/CLUSTER_ID
  network:
    cni:
      name: none
    dnsDomain: cluster.local
    podSubnets:
      - 10.42.0.0/16
      - fdf3:0f3a:242e:42::/108
    serviceSubnets:
      - 10.43.0.0/16
      - fdf3:0f3a:242e:43::/108
  secret: ref+op://hive/talos/CLUSTER_SECRET
  token: ref+op://hive/talos/BOOTSTRAPTOKEN
  {% if ENV.CONTROLPLANE %}
  aggregatorCA:
    crt: ref+op://hive/talos/CERT_K8SAGGREGATOR_CRT
    key: ref+op://hive/talos/CERT_K8SAGGREGATOR_KEY
  allowSchedulingOnControlPlanes: true
  apiServer:
    auditPolicy:
      apiVersion: audit.k8s.io/v1
      kind: Policy
      rules:
        - level: Metadata
    certSANs:
      - k8s.labx.internal
    disablePodSecurityPolicy: true
    extraArgs:
      enable-aggregator-routing: "true"
      feature-gates: HPAScaleToZero=true
    image: registry.k8s.io/kube-apiserver:v1.36.2
  controllerManager:
    extraArgs:
      bind-address: 0.0.0.0
      node-cidr-mask-size-ipv6: "112"
      feature-gates: HPAScaleToZero=true
    image: registry.k8s.io/kube-controller-manager:v1.36.2
  coreDNS:
    disabled: true
  etcd:
    advertisedSubnets:
      - 10.0.30.0/24
    ca:
      crt: ref+op://hive/talos/CERT_ETCD_CRT
      key: ref+op://hive/talos/CERT_ETCD_KEY
    extraArgs:
      listen-metrics-urls: http://0.0.0.0:2381
  proxy:
    disabled: true
    image: registry.k8s.io/kube-proxy:v1.36.2
  scheduler:
    config:
      apiVersion: kubescheduler.config.k8s.io/v1
      kind: KubeSchedulerConfiguration
      profiles:
        - schedulerName: default-scheduler
          plugins:
            score:
              disabled:
                - name: ImageLocality
          pluginConfig:
            - name: PodTopologySpread
              args:
                defaultingType: List
                defaultConstraints:
                  - maxSkew: 1
                    topologyKey: kubernetes.io/hostname
                    whenUnsatisfiable: ScheduleAnyway
    extraArgs:
      bind-address: 0.0.0.0
    image: registry.k8s.io/kube-scheduler:v1.36.2
  secretboxEncryptionSecret: ref+op://hive/talos/SECRETBOXENCRYPTIONSECRET
  serviceAccount:
    key: ref+op://hive/talos/CERT_K8SSERVICEACCOUNT_KEY
  {% endif %}
---
apiVersion: v1alpha1
kind: LinkAliasConfig
name: net0
selector:
  match: mac(link.permanent_addr) == "58:47:ca:7f:c1:0d"
---
apiVersion: v1alpha1
kind: BondConfig
name: bond0
links:
  - net0
bondMode: active-backup
mtu: 9000
---
apiVersion: v1alpha1
kind: DHCPv4Config
name: bond0
clientIdentifier: mac
---
apiVersion: v1alpha1
kind: VLANConfig
name: bond0.4
vlanID: 4
parent: bond0
mtu: 9000
---
apiVersion: v1alpha1
kind: VLANConfig
name: bond0.10
vlanID: 10
parent: bond0
mtu: 9000
---
apiVersion: v1alpha1
kind: VolumeConfig
name: EPHEMERAL
provisioning:
  diskSelector:
    match: disk.transport == "nvme" && system_disk
  maxSize: 50%
---
apiVersion: v1alpha1
kind: RawVolumeConfig
name: miroir
provisioning:
  diskSelector:
    match: disk.transport == "nvme" && system_disk
  minSize: 300GiB
---
apiVersion: v1alpha1
kind: WatchdogTimerConfig
device: /dev/watchdog0
timeout: 5m
